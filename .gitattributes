# Ensure consistent line endings regardless of contributor OS settings.
# Go and shell tooling (gofmt, golangci-lint, sh) all expect LF.
*               text=auto eol=lf
*.go            text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.sh            text eol=lf
Makefile        text eol=lf
go.mod          text eol=lf
go.sum          text eol=lf
*.png           binary
*.jpg           binary
*.gif           binary
*.ico           binary
